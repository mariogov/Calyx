{
  "uid": "calyx-main",
  "title": "Calyx — Association Engine",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "tags": [
    "calyx",
    "ph66"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ingest latency p95",
      "description": "p95 ingest-batch wall-clock latency (calyx_ingest_duration_seconds). Normal: < 0.5s; sustained > 2s indicates flush/compaction pressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum(rate(calyx_ingest_duration_seconds_bucket[5m])) by (le, vault))",
          "refId": "A",
          "legendFormat": "{{vault}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ingest rate",
      "description": "Ingest ops/sec by status (calyx_ingest_total). A rising err rate is the signal; ok rate tracks load.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(calyx_ingest_total[5m])) by (vault, status)",
          "refId": "A",
          "legendFormat": "{{vault}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Search latency p99 by strategy",
      "description": "p99 search latency per retrieval strategy (calyx_search_duration_seconds). Normal: < 0.1s single_lens; rrf/weighted_rrf higher.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.99, sum(rate(calyx_search_duration_seconds_bucket[5m])) by (le, strategy))",
          "refId": "A",
          "legendFormat": "{{strategy}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Search recall tripwire",
      "description": "1 = recall at/above threshold (green), 0 = tripped (red). calyx_search_recall_tripwire. Pre-initialised to 1; 0 fires CalyxRecallTripwire.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "calyx_search_recall_tripwire",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Guard FAR by slot",
      "description": "Guard false-accept rate per required slot (calyx_guard_far). Normal: < 0.05; CalyxGuardFARDrift fires above 0.05.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "calyx_guard_far",
          "refId": "A",
          "legendFormat": "{{vault}} {{slot}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Guard FRR by slot",
      "description": "Guard false-reject rate per required slot (calyx_guard_frr). Normal operating range is workload-dependent; watch for spikes.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "calyx_guard_frr",
          "refId": "A",
          "legendFormat": "{{vault}} {{slot}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "DDA effective sample size (n_eff)",
      "description": "DDA effective sample size per panel (calyx_assay_n_eff). Higher is better; a collapse toward 1 means the panel lost diversity.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "calyx_assay_n_eff",
          "refId": "A",
          "legendFormat": "{{panel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 8
              },
              {
                "color": "green",
                "value": 32
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kernel recall ratio by scope",
      "description": "Kernel-answer recall vs brute force per scope (calyx_kernel_recall_ratio). Normal: >= 0.95; lower means the kernel funnel is dropping hits.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "calyx_kernel_recall_ratio",
          "refId": "A",
          "legendFormat": "{{scope}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "max": 1
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Anneal A/B exposures by variant",
