# ============================================================================
#  Calyx — environment TEMPLATE (tracked; NAMES ONLY, no secret values)
#  Copy to `.env` and fill in values. `.env` is gitignored. Doctrine §8c:
#  never commit a secret value — env-var names only.
# ============================================================================

# ── Cisco AnyConnect VPN (must be UP before SSH) ────────────────────────────
AIWONDER_VPN_SERVER=
AIWONDER_VPN_USER=
AIWONDER_VPN_PASSWORD=

# ── SSH into aiwonder ───────────────────────────────────────────────────────
AIWONDER_HOST=aiwonder.mst.com
AIWONDER_IP=
AIWONDER_SSH_PORT=22
AIWONDER_USER=croyse
AIWONDER_SSH_PASSWORD=
AIWONDER_SUDO_PASSWORD=

# ── Self-contained Calyx root on aiwonder ───────────────────────────────────
CALYX_HOME=/home/croyse/calyx
CALYX_HOT_DATASET=hotpool/calyx
CALYX_COLD_DATASET=archive/calyx
CALYX_HOT_PATH=/zfs/hot/calyx
CALYX_COLD_PATH=/zfs/archive/calyx
CALYX_CARGO_TARGET_DIR=/home/croyse/calyx/target
CALYX_RUST_ENV=/home/croyse/.cargo/env
CALYX_ORT_LIB_DIR=/home/croyse/calyx/vendor/onnxruntime-v1.26.0/build/Linux/Release
ORT_DYLIB_PATH=/home/croyse/calyx/vendor/onnxruntime-v1.26.0/build/Linux/Release/libonnxruntime.so

# ── Resident services to reuse ──────────────────────────────────────────────
AIWONDER_TEI_GENERAL=http://127.0.0.1:8088
AIWONDER_TEI_RERANKER=http://127.0.0.1:8089
AIWONDER_TEI_LEGAL=http://127.0.0.1:8090
AIWONDER_PROMETHEUS=http://127.0.0.1:9090

# ── Hugging Face ────────────────────────────────────────────────────────────
HF_TOKEN=
HF_HUB_TOKEN=
HF_HOME=/home/croyse/calyx/.hf-cache

# ── GitHub dev-state surface ────────────────────────────────────────────────
CALYX_REPO=chrisroyse/calyx-dev
